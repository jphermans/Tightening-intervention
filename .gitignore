# Editor / IDE
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# Node (the project doesn't have a package.json that depends on anything,
# but ignore node_modules if it ever shows up)
node_modules/
package-lock.json

# Test artefacts — local screenshots, JSON exports, generated PDFs.
# These are useful during development but bloat the repo.
test-output/

# OS metadata and editor temp files
*.tmp
*~
.DS_Store
.AppleDouble
.LSOverride

# Local Python http server logs (used during manual testing only)
*.log

# Local SQLite database created by server.py; keep it beside the site/USB stick,
# but out of source control.
data/
intervention_reports.sqlite3
intervention_reports.sqlite3-*

# Optional bundled runtime for fully offline USB-stick use.
# Keep the scaffold docs/markers tracked, but ignore actual interpreter files.
runtime/*
!runtime/.gitkeep
!runtime/README.md
!runtime/START-HERE.md
!runtime/LAUNCH-NOTES.txt
!runtime/USB-STICK-CHECKLIST.md
!runtime/python/
runtime/python/*
!runtime/python/.gitkeep
!runtime/python/bin/
runtime/python/bin/*
!runtime/python/bin/.gitkeep
